 "html": "<style>\n/* =========================\n   P\u00c1GINA SEM MARGEM\n   ========================= */\n@page {\n  margin: 0;\n}\n\n/* =========================\n   ETIQUETA COLADA \u00c0 ESQUERDA\n   ========================= */\nbody {\n  margin: 0;\n  padding: 0;\n}\n\n.etiqueta {\n  position: absolute;\n  top: 0mm;\n  left: 6mm;\n  width: 10cm;\n  height: 15cm;\n  line-height: 2mm;\n  font-size: 3,5mm;\n}\n\n.etiqueta p {\n  margin: 0;\n  padding: 0;\n  line-height: 1;\n  font-family: Arial, sans-serif;\n}\n\n.box {\n    border: 1px solid #000;\n    padding: 4mm;\n    margin-top: 4mm;\n    width: 94%;\n    box-sizing: border-box;\n}\n\n.box h3 {\n    margin-top: 0;\n    margin-bottom: 2mm;\n}\n</style>\n\n\n<div class=\"etiqueta\">\n\n  <div style=\"text-align: center;\">\n      <br><br>\n    <img src=\"/files/PNG ER Anal\u00edtica pretoe575e7.png\"style=\"width: 130px;\">\n</div>\n\n  <div class=\"info-topo\">\n<p>\n  <strong style=\"font-size:15px;\">{{ doc.name }}</strong> \n</p><br>\n<p>\n  <strong style=\"font-size:15px;\">VOLUMES:</strong>   {{ doc.qtd_nf }}\n</p><br>\n<p>\n  <strong style=\"font-size:15px;\">A/C:</strong> {% set contact = frappe.db.get_value(\"Contact\", doc.contact_link, [\"first_name\", \"last_name\"]) %}\n\n{% if contact %}\n  {{ contact[0] }} {{ contact[1] }}\n{% endif %}\n</p><br>\n\n  <div class=\"box\">\n    <h3>Remetente</h3>\n    <br>\n    <p><strong>Nome:</strong> ER Anal\u00edtica</p><br>\n    <p><strong>Endere\u00e7o:</strong> AV MARGINAL RIO JUNDIAI, 2665</p><br>\n    <p>V\u00e1rzea Paulista-SP</p><br>\n    <p><strong>CEP:</strong> 13222-760</p><br>\n    <br>\n\n    <h3>Destinat\u00e1rio</h3>\n    <br>\n    <p><strong>Nome:</strong> {{ doc.customer }}</p><br>\n    <p><strong>Endere\u00e7o:</strong>\n\n{% set address = frappe.db.get_all(\n    \"Address\",\n    filters={\n        \"link_name\": doc.customer,\n        \"link_doctype\": \"Customer\"\n    },\n    fields=[\"cep\", \"address_line1\", \"numero\", \"bairro\", \"city\", \"uf\", \"address_line2\"],\n    limit=1\n) %}\n\n{% if address %}\n  {% set addr = address[0] %}\n\n  {% if addr.address_line1 %}\n  {{ addr.address_line1 }}{% if addr.numero %} - {{ addr.numero }}{% endif %}\n  {% endif %}\n</p><br>\n  {% if addr.city %}\n   <p>   {{ addr.city }}{% if addr.uf %} - {{ addr.uf }}</p>  {% endif %}\n  {% endif %}\n{% endif %}\n<br><br>\n    <p><strong>CEP:</strong>   {% if address %}\n  \n  {% if addr.cep %}\n     {{ addr.cep }}  <br>\n  {% endif %}\n{% endif %}</p>  <br>\n  </div>\n\n<br>\n    <div style=\"text-align: center;\">\n    <img src=\"/files/qrcode_sited9ad4d.jpeg\" style=\"width: 70px;\">\n    <p>www.eranalitica.com.br</p>\n    <p>(11) 4606-7200</p>\n \n  </div>\n\n</div>",
